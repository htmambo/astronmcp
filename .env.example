# =============================================================================
# Astron MCP - 讯飞星火 / Coding Plan 环境变量示例
# =============================================================================

# 接入模式：
#   coding    -> 讯飞星辰 MaaS Coding Plan（OpenAI 协议，推荐用于 Claude Code）
#   http      -> 星火大模型通用 OpenAI 兼容接口
#   websocket -> 星火大模型原生 WebSocket 接口
SPARK_MODE=coding

# ------------------------------------------------------------------------------
# Coding Plan / HTTP 模式必填
# ------------------------------------------------------------------------------
# Coding Plan：从「套餐订阅」页面复制的专属 API Key
# HTTP 模式：对应版本页面的 APIPassword
SPARK_API_PASSWORD=your-api-key-or-password

# ------------------------------------------------------------------------------
# 仅 WebSocket 模式必填
# ------------------------------------------------------------------------------
# SPARK_APP_ID=your-app-id
# SPARK_API_KEY=your-api-key
# SPARK_API_SECRET=your-api-secret

# ------------------------------------------------------------------------------
# 可选配置
# ------------------------------------------------------------------------------
# Coding Plan 默认使用 astron-code-latest；底层模型在控制台「配置模型」切换
SPARK_DEFAULT_MODEL=astron-code-latest

# 请求超时（秒）
SPARK_TIMEOUT_SECONDS=120

# 上下文历史字符上限（粗略估算，用于历史裁剪）
# Coding Plan 建议 96k 以内（对应官方 contextWindow 建议）
SPARK_MAX_CONTEXT_CHARS=96000

# 单会话最大消息条数
SPARK_MAX_MESSAGES=40

# 单次最大输出 tokens
SPARK_MAX_TOKENS=8192

# HTTP 端点（通常无需修改）
# SPARK_API_URL=https://maas-coding-api.cn-huabei-1.xf-yun.com/v2/chat/completions

# WebSocket 端点（仅 websocket 模式使用）
# SPARK_WS_URL=wss://spark-api.xf-yun.com/v4.0/chat
